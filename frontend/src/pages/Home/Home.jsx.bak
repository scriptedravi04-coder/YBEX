// Specific neon/brand color mapping to make brands colorful on hover
const BRAND_COLORS = {
  apple: { border: 'hover:border-white/40', rgb: '255, 255, 255', textClass: 'text-white' },
  nike: { border: 'hover:border-[#FF5E3A]/40', rgb: '255, 94, 58', textClass: 'text-[#FF5E3A]' },
  tesla: { border: 'hover:border-[#FF1E27]/40', rgb: '255, 30, 39', textClass: 'text-[#FF1E27]' },
  spotify: { border: 'hover:border-[#1DB954]/40', rgb: '29, 185, 84', textClass: 'text-[#1DB954]' },
  netflix: { border: 'hover:border-[#E50914]/40', rgb: '229, 9, 20', textClass: 'text-[#E50914]' },
  amazon: { border: 'hover:border-[#FF9900]/40', rgb: '255, 153, 0', textClass: 'text-[#FF9900]' }
};

const getBrandColorStyle = (name, index) => {
  const key = name.toLowerCase();
  for (const brandKey in BRAND_COLORS) {
    if (key.includes(brandKey)) return BRAND_COLORS[brandKey];
  }
  // Alternate fallbacks for database/custom brands
  const colors = [
    { border: 'hover:border-[#E4F141]/40', rgb: '228, 241, 65', textClass: 'text-[#E4F141]' },
    { border: 'hover:border-[#06b6d4]/40', rgb: '6, 182, 212', textClass: 'text-[#06b6d4]' },
    { border: 'hover:border-[#a855f7]/40', rgb: '168, 85, 247', textClass: 'text-[#a855f7]' },
    { border: 'hover:border-[#22c55e]/40', rgb: '34, 197, 94', textClass: 'text-[#22c55e]' },
    { border: 'hover:border-[#ec4899]/40', rgb: '236, 72, 153', textClass: 'text-[#ec4899]' }
  ];
  return colors[index % colors.length];
};

// Reusable Native 3D Perspective Tilt Component
function TiltCard({ children, className, index = 0, style = {}, brandGlow = null }) {
  const cardRef = useRef(null);

  const handleMouseMove = (e) => {
    if (!cardRef.current) return;
    const card = cardRef.current;
    const rect = card.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;

    const centerX = rect.width / 2;
    const centerY = rect.height / 2;
    // Calculate rotation: 10deg max rotation
    const rotateX = (centerY - y) / 10;
    const rotateY = (x - centerX) / 10;

    card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.04, 1.04, 1.04)`;
    card.style.setProperty('--mouse-x', `${x}px`);
    card.style.setProperty('--mouse-y', `${y}px`);
  };

  const handleMouseLeave = () => {
    if (!cardRef.current) return;
    const card = cardRef.current;
    card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
  };

  const glowStyles = brandGlow
    ? { '--glow-color-rgb': brandGlow.rgb }
    : { '--glow-color-rgb': '228, 241, 65' };

  return (
    <div
      ref={cardRef}
      onMouseMove={handleMouseMove}
      onMouseLeave={handleMouseLeave}
      className={`${className} interactive-glow-card transition-transform duration-300 ease-out`}
      style={{
        transformStyle: 'preserve-3d',
        willChange: 'transform',
        ...glowStyles,
        ...style
      }}
    >
      {children}
    </div>
  );
}

// 3D Animated Viewport Graphic driven by AnimeJS
function Service3DGraphic({ activeIndex }) {
  const containerRef = useRef(null);

  useEffect(() => {
    // Trigger animeJS entrance morphing and elastic scale
    animate('.wireframe-item-sub', {
      scale: [0.4, 1],
      opacity: [0, 1],
      translateY: [25, 0],
      duration: 900,
      ease: 'easeOutElastic(1, .6)',
      delay: stagger(80)
    });
  }, [activeIndex]);

  return (
    <div ref={containerRef} className="relative w-full h-[350px] flex items-center justify-center ybex-3d-scene border border-white/5 rounded-2xl overflow-hidden shadow-2xl">
      {/* 3D Radial Grid Mesh */}
      <div className="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(228,241,65,0.07)_0%,transparent_68%)] pointer-events-none" />

      {/* Orbit Rings (3D rotated container) */}
      <div className="relative w-64 h-64 preserve-3d" style={{ transform: 'perspective(800px) rotateX(60deg) rotateY(0deg)' }}>

        {/* Outer Ring */}
        <div className="absolute inset-0 border border-dashed border-[#E4F141]/25 rounded-full animate-[spin_25s_linear_infinite]" />
        {/* Middle Ring */}
        <div className="absolute inset-6 border border-dashed border-[#a855f7]/30 rounded-full animate-[spin_18s_linear_infinite_reverse]" />
        {/* Inner Ring */}
        <div className="absolute inset-12 border border-dotted border-[#06b6d4]/45 rounded-full animate-[spin_10s_linear_infinite]" />

        {/* Staggered Geometric Nodes */}
        <div className="absolute inset-16 flex items-center justify-center preserve-3d">
          {activeIndex === 0 && (
            <div className="flex gap-3 preserve-3d">
              <div className="wireframe-item-sub w-6 h-6 bg-[#E4F141] rounded-full shadow-[0_0_20px_rgba(228,241,65,0.8)]" />
              <div className="wireframe-item-sub w-6 h-6 bg-[#a855f7] rounded-full shadow-[0_0_20px_rgba(168,85,247,0.8)]" />
              <div className="wireframe-item-sub w-6 h-6 bg-[#06b6d4] rounded-full shadow-[0_0_20px_rgba(6,182,212,0.8)]" />
            </div>
          )}
          {activeIndex === 1 && (
            <div className="relative w-20 h-20 border-2 border-[#E4F141]/30 rounded-2xl flex items-center justify-center preserve-3d wireframe-item-sub animate-[spin_8s_linear_infinite]">
              <div className="w-10 h-10 bg-[#E4F141] rounded-xl shadow-[0_0_25px_#E4F141]" />
            </div>
          )}
          {activeIndex === 2 && (
            <div className="relative w-24 h-24 preserve-3d flex items-center justify-center wireframe-item-sub">
              <div className="absolute w-full h-1 bg-[#a855f7] rotate-45 shadow-[0_0_15px_#a855f7]" />
              <div className="absolute w-full h-1 bg-[#E4F141] -rotate-45 shadow-[0_0_15px_#E4F141]" />
              <div className="w-8 h-8 rounded-full bg-white shadow-[0_0_20px_#fff] z-10" />
            </div>
          )}
          {activeIndex === 3 && (
            <div className="flex flex-col gap-2.5 preserve-3d wireframe-item-sub">
              <div className="w-16 h-2 bg-[#06b6d4] rounded-full shadow-[0_0_12px_#06b6d4]" />
              <div className="w-20 h-2 bg-[#E4F141] rounded-full shadow-[0_0_12px_#E4F141]" />
              <div className="w-12 h-2 bg-[#a855f7] rounded-full shadow-[0_0_12px_#a855f7]" />
            </div>
          )}
          {activeIndex === 4 && (
            <div className="relative w-20 h-20 preserve-3d flex items-center justify-center wireframe-item-sub">
              <div className="absolute inset-0 border-2 border-dashed border-[#E4F141]/40 rounded-full animate-ping" />
              <div className="w-8 h-8 bg-white rounded-full shadow-[0_0_20px_#fff]" />
            </div>
          )}
          {activeIndex === 5 && (
            <div className="flex items-end gap-1.5 h-16 preserve-3d wireframe-item-sub">
              <div className="w-3.5 h-8 bg-[#06b6d4] rounded-t shadow-[0_0_10px_#06b6d4]" />
              <div className="w-3.5 h-14 bg-[#E4F141] rounded-t shadow-[0_0_10px_#E4F141]" />
              <div className="w-3.5 h-5 bg-[#a855f7] rounded-t shadow-[0_0_10px_#a855f7]" />
            </div>
          )}
        </div>
      </div>

      {/* Technical Blueprint Display */}
      <div className="absolute bottom-6 left-6 right-6 bg-black/80 border border-white/5 p-5 rounded-xl backdrop-blur-md z-20">
        <span className="text-[8px] font-mono text-[#E4F141] uppercase tracking-widest block">System Status // Active // 3D Scene</span>
        <div className="flex justify-between items-center mt-1">
          <span className="text-xs text-white uppercase font-black tracking-wide font-mono">
            {activeIndex === 0 ? 'MKTG_ENGINE_RUN' :
              activeIndex === 1 ? 'BRAND_PROM_RUN' :
                activeIndex === 2 ? 'LOGIST_MGMT_RUN' :
                  activeIndex === 3 ? 'CONT_STRAT_RUN' :
                    activeIndex === 4 ? 'SOC_GROWTH_RUN' : 'LIVE_ANAL_RUN'}
          </span>
          <span className="text-[10px] text-white/40 font-mono">
            PERSPECTIVE_LOADED_OK
          </span>
        </div>
      </div>
    </div>
  );
}

export default function Home() {
  const [brands, setBrands] = useState([]);
  const [brandsLoading, setBrandsLoading] = useState(true);
  const [creators, setCreators] = useState([]);
  const [creatorsLoading, setCreatorsLoading] = useState(true);

  // Active Index for Services console
  const [activeServiceIdx, setActiveServiceIdx] = useState(0);

  // Email state for newsletter
  const [emailInput, setEmailInput] = useState('');
  const [subscribed, setSubscribed] = useState(false);

  // Fetch brands from database
  useEffect(() => {
    axiosInstance.get('/brands')
      .then((res) => setBrands(res.data.brands || []))
      .catch(() => setBrands([]))
      .finally(() => setBrandsLoading(false));
  }, []);

  // Fetch creators from database
  useEffect(() => {
    axiosInstance.get('/creators')
      .then((res) => setCreators(res.data.creators || []))
      .catch(() => setCreators([]))
      .finally(() => setCreatorsLoading(false));
  }, []);

  const handleSubscribeSubmit = (e) => {
    e.preventDefault();
    if (emailInput.trim()) {
      setSubscribed(true);
      setEmailInput('');
      setTimeout(() => setSubscribed(false), 3000);
    }
  };

  // Map gallery creators from database or fallback to talentProfiles
  const galleryCreators = creators.length > 0
    ? creators.map((c) => ({
      _id: c._id,
      name: c.name,
      imageUrl: c.imageUrl,
      followersCount: c.followersCount || '800K',
      reach: c.reach || '3M+',
      engagementRate: c.engagementRate || '7.2%'
    }))
    : talentProfiles.map((item, idx) => ({
      _id: `mock-creator-${idx}`,
      name: item.name,
      imageUrl: item.image,
      followersCount: idx === 0 ? '2.4M' : idx === 1 ? '1.8M' : idx === 2 ? '950K' : idx === 3 ? '1.2M' : idx === 4 ? '3.1M' : idx === 5 ? '880K' : '2.1M',
      reach: idx === 0 ? '12M+' : idx === 1 ? '9.5M+' : idx === 2 ? '5.2M+' : idx === 3 ? '6.8M+' : idx === 4 ? '15M+' : idx === 5 ? '4.8M+' : '10M+',
      engagementRate: idx === 0 ? '8.4%' : idx === 1 ? '7.2%' : idx === 2 ? '9.1%' : idx === 3 ? '7.8%' : idx === 4 ? '8.9%' : idx === 5 ? '6.7%' : '7.5%'
    }));

  // Map display brands from fetched or fallback mock list
  const displayBrands = brands.length > 0
    ? brands.map((b) => ({
      name: b.name,
      logo: b.logoUrl ? resolveImg(b.logoUrl) : null,
      desc: 'Partner Brand',
      isDb: true,
      link: b.websiteLink
    }))
    : MOCK_HERO_BRANDS;

  // Services list content (no icons, matching design console)
  const SERVICES_LIST = [
    { title: 'Influencer Marketing', desc: 'Match with targeted influencers, align campaigns, and track results automatically.', id: 'OPS-01' },
    { title: 'Brand Promotions', desc: 'Maximize product awareness across channels using creator generated short-form assets.', id: 'MKTG-02' },
    { title: 'Campaign Management', desc: 'Secure operational logistics from creation briefs to contract payouts.', id: 'MGMT-03' },
    { title: 'Content Strategy', desc: 'Structure media hooks and timelines customized to retain consumer interest.', id: 'ART-04' },
    { title: 'Social Growth', desc: 'Expand organic channel visibility using verified algorithms and sharing workflows.', id: 'GROW-05' },
    { title: 'Analytics', desc: 'Track CPC, CTR, CPV, and conversions on a live platform dashboard.', id: 'DATA-06' }
  ];

  // GSAP Entrance timelines and reveals
  useEffect(() => {
    const ctx = gsap.context(() => {
      // 1. Hero timeline animation
      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

      tl.fromTo('.hero-badge-anim',
        { opacity: 0, y: -15 },
        { opacity: 1, y: 0, duration: 0.4, delay: 0.1 }
      )
        .fromTo('.hero-title-anim',
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, duration: 0.5 },
          '-=0.3'
        )
        .fromTo('.hero-desc-anim',
          { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.4 },
          '-=0.45'
        )
        .fromTo('.hero-btn-anim',
          { opacity: 0, y: 8 },
          { opacity: 1, y: 0, duration: 0.3, stagger: 0.08 },
          '-=0.35'
        )
        .fromTo('.three-d-gallery-wrapper',
          { opacity: 0, y: 30, scale: 0.98 },
          { opacity: 1, y: 0, scale: 1, duration: 0.6, ease: 'power3.out' },
          '-=0.5'
        );
    });

    // 2. Intersection Observer for Scroll Reveals
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1,
    };

    const handleIntersect = (entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target;
          target.classList.add('scroll-reveal-active');
          observer.unobserve(target);
        }
      });
    };

    const observer = new IntersectionObserver(handleIntersect, observerOptions);
    const elements = document.querySelectorAll('.scroll-reveal-left, .scroll-reveal-right, .scroll-reveal-up-custom');
    elements.forEach((el) => observer.observe(el));

    return () => {
      ctx.revert();
      observer.disconnect();
    };
  }, [brandsLoading, creatorsLoading]);

  return (
    <div className="minimal-home-container relative min-h-screen">
      {/* Background ambient spots */}
      <div className="glow-spot glow-spot-yellow" />
      <div className="glow-spot glow-spot-purple" />
      <div className="glow-spot glow-spot-cyan" />

      {/* Mesh Background */}
      <div className="minimal-bg-mesh" />

      {/* Cursor Particles Background */}
      <CursorParticlesBackground />

      {/* ── HERO SECTION ── */}
      <section className="relative pt-[36px] md:pt-[64px] pb-12 px-4 md:px-8 border-b border-white/5 z-10 overflow-hidden">
        <div className="max-w-7xl mx-auto flex flex-col items-center">

          {/* Centered Column: Text & Action Hub */}
          <div className="text-center flex flex-col items-center justify-center pt-0 pb-6 px-2 max-w-4xl">
            <div className="hero-badge-anim hidden"></div>

            <h1 className="hero-title-anim text-4xl sm:text-5xl md:text-[64px] font-black text-white tracking-tight leading-[1.05] uppercase">
              Connecting Brands With <span className="accent-yellow-text">Elite Creators</span>
            </h1>

            <p className="hero-desc-anim text-xs sm:text-sm md:text-base text-white/60 font-medium max-w-2xl mx-auto mt-6 leading-relaxed">
              We drive viral campaign operations and track verified performance metrics.
            </p>

            {/* CTA Buttons */}
            <div className="flex flex-wrap gap-4 justify-center items-center mt-10 z-20">
              <Link
                to="/get-started"
                className="hero-btn-anim btn-yellow px-9 py-4 rounded-full text-xs uppercase tracking-widest"
              >
                Get Started
              </Link>

              <Link
                to="/creators"
                className="hero-btn-anim btn-outline px-9 py-4 rounded-full text-xs uppercase tracking-widest"
              >
                Explore Influencers
              </Link>
            </div>
          </div>

          {/* Centered 3D curved gallery with scanning left/right split */}
          <ThreeDCurvedGallery creators={galleryCreators} brands={displayBrands} />

        </div>
      </section>

      {/* ── INFINITE MARQUEE (GIF strip) ── */}
      <InfiniteMarquee />

      {/* ── TESTIMONIAL QUOTE SECTION (Chris Halaska parallax) ── */}
      <TestimonialSection />

      {/* ── PRICING SECTION ── */}
      <PricingSection />

      {/* ── TESTIMONIAL CAROUSEL ── */}
      <TestimonialCarousel />

      {/* ── PROJECTS SECTION ── */}
      <ProjectsSection />

      {/* ── PARTNER SECTION ── */}
      <PartnerSection />

      {/* ── EngineTech SITE FOOTER ── */}
      <EngineTechFooter />

      {/* ── FIXED BOTTOM NAV ── */}
      <BottomNav />
    </div>
  );
}
